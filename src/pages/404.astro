---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="404 - Page Not Found" activeNav="home">
	<style>
		.error-container {
			margin: 100px auto;
			max-width: 600px;
			text-align: center;
			padding: 60px 20px;
		}
		.error-container h1 {
			margin: 30px 0;
			font-size: 8em;
			line-height: 1;
			letter-spacing: -1px;
			color: #4e66f8;
			font-weight: 700;
		}
		.error-container h2 {
			margin: 20px 0;
			font-size: 2em;
			font-weight: 600;
		}
		.error-container p {
			font-size: 1.2em;
			color: #666;
			margin: 20px 0;
		}
		.error-container .btn-home {
			display: inline-block;
			margin-top: 30px;
			padding: 15px 40px;
			background: #4e66f8;
			color: #fff;
			text-decoration: none;
			border-radius: 5px;
			font-weight: 600;
			transition: all 0.3s ease;
		}
		.error-container .btn-home:hover {
			background: #3a52d4;
			transform: translateY(-2px);
			box-shadow: 0 5px 15px rgba(78, 102, 248, 0.3);
		}
	</style>

	<div class="error-container">
		<h1>404</h1>
		<h2>Page Not Found</h2>
		<p><strong>Oops! The page you are looking for doesn't exist.</strong></p>
		<p>It might have been moved or deleted.</p>
		<a href="/" class="btn-home">Back to Home</a>
	</div>
</MainLayout>
